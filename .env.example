# Copy to .env to override defaults (.env is git-ignored — put real secrets there).
# docker-compose sets DATABASE_URL itself.

# --- API ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/store
STORE_LAYOUT_PATH=data/store_layout.json
POS_CSV_PATH=data/pos_transactions.csv
LOG_LEVEL=INFO

# Business windows / thresholds
CONVERSION_WINDOW_MINUTES=5
STALE_FEED_MINUTES=10
DEAD_ZONE_MINUTES=30
QUEUE_SPIKE_WARN=4
QUEUE_SPIKE_CRITICAL=7

# --- Detection pipeline (host) ---
YOLO_WEIGHTS=yolov8n.pt
YOLO_IMGSZ=640
DET_CONF=0.15

# Optional VLM staff classification (off by default).
USE_VLM_STAFF=0
VLM_PROVIDER=groq                 # groq | anthropic
# GROQ_API_KEY=gsk_...            # put the real key in .env, NOT here
# ANTHROPIC_API_KEY=sk-ant-...
